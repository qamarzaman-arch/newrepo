// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Enums

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  KITCHEN
  WAITER
  RIDER
  STAFF
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  VOIDED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
  FAILED
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  EXPIRED
}

enum KotStation {
  GRILL
  FRYER
  COLD
  BAKERY
  BEVERAGE
  HOT
  SALAD
  DESSERT
  MAIN
}

// Models
model User {
  id           String    @id @default(uuid())
  username     String    @unique
  email        String?   @unique
  passwordHash String
  fullName     String
  role         String    @default("STAFF")
  pin          String?
  phone        String?
  avatar       String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  // Rider-specific fields
  status          String?   @default("ACTIVE")
  isAvailable     Boolean   @default(true)
  lastLocationLat Decimal?  @db.Decimal(10, 8)
  lastLocationLng Decimal?  @db.Decimal(11, 8)
  lastLocationAt  DateTime?
  vehicleType     String?
  vehiclePlate    String?

  orders             Order[]                    @relation("CashierOrders")
  servedOrders       Order[]                    @relation("ServerOrders")
  expenses           Expense[]
  shifts             Shift[]
  auditLogs          AuditLog[]
  deliveries         Delivery[]                 @relation("RiderDeliveries")
  sessions           Session[]
  deliveryZones      DeliveryZone[]             @relation("DeliveryZoneCreator")
  tableLocks         TableLock[]
  orderModifications OrderModificationHistory[]
  StaffPerformance   StaffPerformance[]
  staffSchedules        StaffSchedule[]      @relation("ScheduledUser")
  swapRequestsSent      ShiftSwapRequest[]   @relation("SwapRequester")
  swapRequestsReceived  ShiftSwapRequest[]   @relation("SwapTarget")
  pinAttempts          PinAttempt[]

  @@index([username])
  @@index([email])
  @@index([role])
  @@index([isAvailable])
}

model PinAttempt {
  id        String   @id @default(uuid())
  userId    String
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([resetAt])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @db.Text
  tokenHash String?  @db.VarChar(64)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model MenuCategory {
  id           String   @id @default(uuid())
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items MenuItem[]

  @@index([displayOrder])
}

model MenuItem {
  id              String   @id @default(uuid())
  categoryId      String
  name            String
  description     String?
  price           Decimal  @db.Decimal(12, 2)
  cost            Decimal  @db.Decimal(12, 2)
  image           String?
  sku             String?
  barcode         String?
  isActive        Boolean  @default(true)
  isAvailable     Boolean  @default(true)
  prepTimeMinutes Int      @default(15)
  taxRate         Decimal  @default(0) @db.Decimal(5, 2)
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category       MenuCategory    @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]
  inventoryItems InventoryItem[]
  modifiers      ItemModifier[]
  tags           MenuItemTag[]
  comboItems     ComboItem[]
  recipes        Recipe[]

  @@unique([sku])
  @@unique([barcode])
  @@index([categoryId])
  @@index([isActive])
  @@index([isAvailable])
  @@index([name])
}

model ItemModifier {
  id           String  @id @default(uuid())
  menuItemId   String
  name         String
  type         String
  isRequired   Boolean @default(false)
  displayOrder Int     @default(0)

  menuItem MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options  ModifierOption[]

  @@index([menuItemId])
}

model ModifierOption {
  id              String  @id @default(uuid())
  modifierId      String
  name            String
  priceAdjustment Decimal @default(0) @db.Decimal(12, 2)
  isDefault       Boolean @default(false)
  displayOrder    Int     @default(0)

  modifier ItemModifier @relation(fields: [modifierId], references: [id], onDelete: Cascade)

  @@index([modifierId])
}

model MenuItemTag {
  id         String @id @default(uuid())
  menuItemId String
  tag        String

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, tag])
  @@index([tag])
}

enum OrderType {
  DINE_IN
  WALK_IN
  TAKEAWAY
  DELIVERY
  PICKUP
  RESERVATION
}

model Order {
  id          String      @id @default(uuid())
  orderNumber String      @unique
  orderType   OrderType   @default(DINE_IN)
  status      String      @default("PENDING")

  customerId    String?
  customerName  String?
  customerPhone String?

  tableId String?

  subtotal        Decimal       @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @db.Decimal(12, 2)
  discountPercent Decimal       @default(0) @db.Decimal(5, 2)
  discountId      String?
  taxAmount       Decimal       @default(0) @db.Decimal(12, 2)
  surchargeAmount Decimal       @default(0) @db.Decimal(12, 2)
  tipAmount       Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @db.Decimal(12, 2)

  paymentMethod String?
  paymentStatus String        @default("PENDING")

  cashierId String
  serverId  String?

  notes        String?
  kitchenNotes String?

  orderedAt    DateTime  @default(now())
  confirmedAt  DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Branch / source
  branchId       String?
  qrSessionId    String?
  externalSource String? // null=in-house, FOODPANDA, UBEREATS, QR

  items               OrderItem[]
  payments            Payment[]
  paymentValidations  PaymentValidation[]
  table               Table?                     @relation(fields: [tableId], references: [id])
  customer            Customer?                  @relation(fields: [customerId], references: [id])
  cashier             User                       @relation("CashierOrders", fields: [cashierId], references: [id])
  server              User?                      @relation("ServerOrders", fields: [serverId], references: [id])
  delivery            Delivery?
  kotTickets          KotTicket[]
  modificationHistory OrderModificationHistory[]
  reviews             CustomerReview[]
  taxFiling           TaxFiling?
  externalOrder       ExternalPlatformOrder?
  qrSession           QrSession?                 @relation("QrSessionOrders", fields: [qrSessionId], references: [id])

  @@index([orderNumber])
  @@index([status])
  @@index([orderedAt])
  @@index([customerId])
  @@index([tableId])
  @@index([cashierId])
  @@index([status, orderedAt])
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  menuItemId String
  quantity   Int     @default(1)
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  notes     String?
  modifiers String?

  status          String    @default("NEW")
  sentToKitchenAt DateTime?
  preparedAt      DateTime?
  voidedAt        DateTime?
  voidedById      String?
  voidReason      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
  @@index([status])
  @@index([status, sentToKitchenAt]) // Kitchen display queries
  @@index([status, preparedAt]) // Kitchen performance queries
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String
  method    String
  amount    Decimal       @db.Decimal(12, 2)
  reference String?
  status    String        @default("PAID")
  paidAt    DateTime      @default(now())
  notes     String?

  // Stripe linkage for refund routing
  stripePaymentIntentId String?
  stripeChargeId        String?
  stripeRefundId        String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([paidAt])
  @@index([status, paidAt]) // Financial reporting queries
  @@index([method, paidAt]) // Payment method reporting
  @@index([orderId, status])
  @@index([stripePaymentIntentId])
}

model PaymentValidation {
  id              String   @id @default(uuid())
  transactionId   String   @unique
  orderId         String?
  amount          Decimal  @db.Decimal(12, 2)
  method          String   @default("CARD")
  status          String
  cardLastFour    String?
  gatewayResponse String?  @db.LongText
  idempotencyKey  String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  order Order? @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([status])
  @@index([orderId])
}

model StripeWebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique
  eventType   String
  processedAt DateTime @default(now())
  payload     String   @db.LongText

  @@index([eventType])
  @@index([processedAt])
}

model Table {
  id             String   @id @default(uuid())
  number         String
  capacity       Int      @default(4)
  status         String   @default("AVAILABLE")
  location       String?
  shape          String?
  isActive       Boolean  @default(true)
  posX           Int?
  posY           Int?
  width          Int?
  height         Int?
  currentOrderId String?  @unique
  version        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders     Order[]
  tableLocks TableLock[]
  qrSessions QrSession[]

  @@index([status])
  @@index([location])
  @@index([number])
  @@index([currentOrderId])
}

model Customer {
  id          String    @id @default(uuid())
  firstName   String
  lastName    String
  email       String?   @unique
  phone       String    @unique
  address     String?
  city        String?
  dateOfBirth DateTime?
  gender      String?
  notes       String?

  loyaltyPoints       Int     @default(0)
  loyaltyPointsFraction Decimal @default(0) @db.Decimal(12, 4)
  totalOrders         Int     @default(0)
  totalSpent          Decimal @default(0) @db.Decimal(14, 2)
  lastVisitAt         DateTime?

  preferences String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders              Order[]
  loyaltyTransactions LoyaltyTransaction[]
  campaignRecipients  CampaignRecipient[]
  reviews             CustomerReview[]
  qrSessions          QrSession[]

  @@index([phone])
  @@index([email])
  @@index([loyaltyPoints])
}

model LoyaltyTransaction {
  id           String   @id @default(uuid())
  customerId   String
  points       Int
  reason       String
  referenceId  String?
  balanceAfter Int
  createdAt    DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdAt])
}

model InventoryItem {
  id         String  @id @default(uuid())
  menuItemId String?
  name       String
  sku        String? @unique
  barcode    String? @unique
  category   String?
  unit       String

  currentStock  Decimal @default(0) @db.Decimal(14, 3)
  minStock      Decimal @default(0) @db.Decimal(14, 3)
  maxStock      Decimal @default(0) @db.Decimal(14, 3)
  reservedStock Decimal @default(0) @db.Decimal(14, 3)

  costPerUnit  Decimal  @default(0) @db.Decimal(12, 4)
  sellingPrice Decimal? @db.Decimal(12, 2)

  supplierId String?

  status   String  @default("IN_STOCK")
  isActive Boolean @default(true)

  warehouseId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menuItem           MenuItem?           @relation(fields: [menuItemId], references: [id])
  supplier           Vendor?             @relation(fields: [supplierId], references: [id])
  warehouse          Warehouse?          @relation(fields: [warehouseId], references: [id])
  movements          StockMovement[]
  adjustments        StockAdjustment[]
  stockAlerts        StockAlert[]
  recipeIngredients  RecipeIngredient[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([warehouseId, menuItemId])
  @@index([sku])
  @@index([status])
  @@index([warehouseId])
  @@index([currentStock])
  @@index([menuItemId, status]) // Stock availability checks
  @@index([status, currentStock]) // Low stock reporting
  @@index([supplierId])
}

model StockMovement {
  id              String   @id @default(uuid())
  inventoryItemId String
  type            String
  quantity        Decimal  @db.Decimal(14, 3)
  previousStock   Decimal  @db.Decimal(14, 3)
  newStock        Decimal  @db.Decimal(14, 3)
  reference       String?
  notes           String?
  performedById   String?
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([inventoryItemId])
  @@index([type])
  @@index([createdAt])
}

model StockAlert {
  id              String    @id @default(uuid())
  inventoryItemId String
  alertType       String // LOW_STOCK, OUT_OF_STOCK, EXPIRED
  message         String?
  isResolved      Boolean   @default(false)
  resolvedAt      DateTime?
  resolvedById    String?
  createdAt       DateTime  @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([alertType])
  @@index([isResolved])
  @@index([createdAt])
}

model StockAdjustment {
  id              String   @id @default(uuid())
  inventoryItemId String
  adjustmentType  String
  quantity        Decimal  @db.Decimal(14, 3)
  reason          String
  notes           String?
  adjustedById    String
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([inventoryItemId])
  @@index([createdAt])
}

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String?
  city      String?
  phone     String?
  manager   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryItems InventoryItem[]

  @@index([code])
}

model KotTicket {
  id           String  @id @default(uuid())
  ticketNumber String  @unique
  orderId      String
  orderItemId  String?

  course   String @default("main")
  status   String @default("NEW")
  priority String @default("normal")
  version  Int    @default(0)

  orderedAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  station    String?
  assignedTo String?

  delayReason String?
  delayedAt   DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([ticketNumber])
  @@index([orderedAt])
  @@index([status, orderedAt])
}

model Delivery {
  id             String @id @default(uuid())
  orderId        String @unique
  deliveryNumber String @unique

  customerName    String
  customerPhone   String
  deliveryAddress String
  deliveryNotes   String?

  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)

  riderId String?
  zoneId  String?

  estimatedTime Int?
  dispatchedAt  DateTime?
  pickedUpAt    DateTime?
  deliveredAt   DateTime?

  status String @default("PENDING")

  deliveryFee Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])
  rider User? @relation("RiderDeliveries", fields: [riderId], references: [id])
  zone  DeliveryZone? @relation("ZoneDeliveries", fields: [zoneId], references: [id])

  @@index([status])
  @@index([riderId])
  @@index([zoneId])
  @@index([deliveryNumber])
  @@index([status, createdAt])
}

model DeliveryZone {
  id                    String   @id @default(uuid())
  name                  String
  description           String?
  baseFee               Decimal  @default(0) @db.Decimal(12, 2)
  minimumOrder          Decimal  @default(0) @db.Decimal(12, 2)
  freeDeliveryThreshold Decimal? @db.Decimal(12, 2)
  estimatedTimeMin      Int
  estimatedTimeMax      Int
  isActive              Boolean  @default(true)
  color                 String?
  coordinates           Json?
  createdById           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  createdBy  User       @relation("DeliveryZoneCreator", fields: [createdById], references: [id])
  deliveries Delivery[] @relation("ZoneDeliveries")

  @@index([isActive])
  @@index([createdById])
}

model Expense {
  id            String  @id @default(uuid())
  expenseNumber String  @unique
  category      String
  description   String
  amount        Decimal @db.Decimal(12, 2)
  paymentMethod String?
  receipt       String?
  notes         String?

  approvedById String?
  createdById  String

  expenseDate DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([category])
  @@index([expenseDate])
  @@index([createdById])
}

model Discount {
  id         String   @id @default(uuid())
  name       String
  code       String?  @unique
  type       String
  value      Decimal  @db.Decimal(12, 2)
  minValue   Decimal? @db.Decimal(12, 2)
  maxValue   Decimal? @db.Decimal(12, 2)
  usageLimit Int?
  usedCount  Int      @default(0)
  isActive   Boolean  @default(true)

  validFrom  DateTime?
  validUntil DateTime?

  applicableTo String  @default("all")
  itemIds      String?
  categoryIds  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive])
}

model Surcharge {
  id           String  @id @default(uuid())
  name         String
  type         String
  value        Decimal @db.Decimal(12, 2)
  isActive     Boolean @default(true)
  applicableTo String  @default("all")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model TaxRate {
  id          String  @id @default(uuid())
  name        String
  rate        Decimal @db.Decimal(5, 2)
  isActive    Boolean @default(true)
  isInclusive Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, isActive])
  @@index([isActive])
}

model CashDrawer {
  id            String @id @default(uuid())
  sessionNumber String @unique

  openedById String
  closedById String?

  openingBalance Decimal  @db.Decimal(12, 2)
  openedAt       DateTime @default(now())

  closingBalance     Decimal? @db.Decimal(12, 2)
  expectedBalance    Decimal? @db.Decimal(12, 2)
  discrepancy        Decimal? @db.Decimal(12, 2)
  discrepancyPercent Decimal? @db.Decimal(7, 4)
  discrepancyFlagged Boolean  @default(false)
  closedAt           DateTime?
  closingNotes       String?

  totalSales       Decimal @default(0) @db.Decimal(14, 2)
  totalCashIn      Decimal @default(0) @db.Decimal(14, 2)
  totalCashOut     Decimal @default(0) @db.Decimal(14, 2)
  transactionCount Int     @default(0)

  status String @default("open")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionNumber])
  @@index([status])
  @@index([openedAt])
  @@index([discrepancyFlagged])
}

model Shift {
  id          String @id @default(uuid())
  userId      String
  shiftNumber String @unique

  clockedInAt  DateTime  @default(now())
  clockedOutAt DateTime?

  scheduledStart DateTime?
  scheduledEnd   DateTime?

  breakStart DateTime?
  breakEnd   DateTime?

  notes  String?
  status String  @default("OPEN")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([clockedInAt])
  @@index([status])
}

model StaffPerformance {
  id     String   @id @default(uuid())
  userId String
  date   DateTime

  ordersHandled   Int     @default(0)
  totalSales      Decimal @default(0) @db.Decimal(14, 2)
  totalCommission Decimal @default(0) @db.Decimal(12, 2)
  avgOrderValue   Decimal @default(0) @db.Decimal(12, 2)
  tips            Decimal @default(0) @db.Decimal(12, 2)
  cancellations   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model Vendor {
  id          String  @id @default(uuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  city        String?
  website     String?
  notes       String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]

  @@index([name])
  @@index([phone])
}

model Setting {
  id       String  @id @default(uuid())
  key      String  @unique
  value    String
  category String?
  dataType String  @default("string")
  isPublic Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([category])
}

model Device {
  id         String    @id @default(uuid())
  name       String
  type       String
  model      String?
  ipAddress  String?
  port       Int?
  config     String?
  isActive   Boolean   @default(true)
  lastSeenAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

// Atomic counter for unique numbers (orders, expenses, KOT, deliveries, sessions, etc.)
// Each `scope` (e.g., "ORDER:2026-05-01") owns its sequence to prevent races.
model SequenceCounter {
  scope     String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

model OrderCounter {
  id        String   @id @default("global")
  count     Int      @default(0)
  date      String // YYYY-MM-DD format
  updatedAt DateTime @updatedAt

  @@index([date])
}

model TableLock {
  id        String   @id @default(uuid())
  tableId   String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model IdempotencyKey {
  id           String   @id @default(uuid())
  key          String   @unique
  requestPath  String
  requestBody  String   @db.LongText
  responseBody String   @db.LongText
  orderId      String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime // TTL for cleanup

  @@index([key])
  @@index([expiresAt])
}

model SyncQueue {
  id           String    @id @default(uuid())
  operation    String
  modelName    String
  recordId     String
  payload      String    @db.LongText
  status       String    @default("pending")
  retryCount   Int       @default(0)
  errorMessage String?
  syncedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([modelName, recordId])
}

model SyncLog {
  id            String  @id @default(uuid())
  action        String
  direction     String
  recordsSynced Int     @default(0)
  status        String
  details       String?
  duration      Int?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}

model AuditLog {
  id        String  @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  changes   String? @db.LongText
  ipAddress String?
  userAgent String?
  requestId String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@index([requestId])
}

model OrderModificationHistory {
  id           String   @id @default(uuid())
  orderId      String
  fieldName    String
  oldValue     String?  @db.LongText
  newValue     String?  @db.LongText
  reason       String?  @db.LongText
  modifiedById String
  modifiedAt   DateTime @default(now())

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  modifiedBy User  @relation(fields: [modifiedById], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([modifiedById])
  @@index([fieldName])
  @@index([modifiedAt])
}

model ReportCache {
  id          String   @id @default(uuid())
  reportType  String
  period      String
  data        String   @db.LongText
  generatedAt DateTime @default(now())
  expiresAt   DateTime

  @@unique([reportType, period])
  @@index([expiresAt])
}

// Combo Meals
model Combo {
  id          String    @id @default(uuid())
  name        String
  description String?
  price       Decimal   @db.Decimal(12, 2)
  isAvailable Boolean   @default(true)
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items ComboItem[]

  @@index([isAvailable])
}

model ComboItem {
  id         String  @id @default(uuid())
  comboId    String
  menuItemId String
  quantity   Int
  price      Decimal @db.Decimal(12, 2)

  combo    Combo    @relation(fields: [comboId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([comboId])
  @@index([menuItemId])
}

// Recipes
model Recipe {
  id              String   @id @default(uuid())
  name            String
  description     String?
  instructions    String?  @db.LongText
  prepTimeMinutes Int      @default(0)
  cookTimeMinutes Int      @default(0)
  servings        Int      @default(1)
  cost            Decimal  @default(0) @db.Decimal(12, 2)
  menuItemId      String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  menuItem    MenuItem?          @relation(fields: [menuItemId], references: [id])
  ingredients RecipeIngredient[]

  @@index([menuItemId])
}

model RecipeIngredient {
  id              String  @id @default(uuid())
  recipeId        String
  inventoryItemId String
  quantity        Decimal @db.Decimal(14, 3)
  unit            String

  recipe        Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([recipeId])
  @@index([inventoryItemId])
}

// Purchase Orders
model PurchaseOrder {
  id               String    @id @default(uuid())
  vendorId         String
  status           String    @default("PENDING")
  notes            String?
  totalAmount      Decimal   @default(0) @db.Decimal(14, 2)
  expectedDelivery DateTime?
  receivedAt       DateTime?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  vendor Vendor              @relation(fields: [vendorId], references: [id])
  items  PurchaseOrderItem[]

  @@index([vendorId])
  @@index([status])
}

model PurchaseOrderItem {
  id               String  @id @default(uuid())
  purchaseOrderId  String
  inventoryItemId  String
  quantity         Decimal @db.Decimal(14, 3)
  unitCost         Decimal @db.Decimal(12, 4)
  receivedQuantity Decimal @default(0) @db.Decimal(14, 3)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

// Feature Access Control
model FeatureAccess {
  id        String   @id @default(uuid())
  feature   String // Feature identifier (e.g., 'orders', 'inventory', 'reports')
  role      String // Role name (e.g., 'ADMIN', 'MANAGER', 'STAFF', 'RIDER')
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([feature, role])
  @@index([feature])
  @@index([role])
}

// ========== MULTI-BRANCH MANAGEMENT ==========
model Branch {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  address      String?
  city         String?
  phone        String?
  email        String?
  managerId    String?
  isHeadOffice Boolean  @default(false)
  isActive     Boolean  @default(true)
  timezone     String?  @default("Asia/Karachi")
  currency     String?  @default("PKR")
  taxId        String? // FBR/PRA/SRB registration number
  openingTime  String?
  closingTime  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns      MarketingCampaign[]
  reviews        CustomerReview[]
  taxFilings     TaxFiling[]
  journalEntries JournalEntry[]
  qrSessions     QrSession[]
  externalOrders ExternalPlatformOrder[]

  @@index([code])
  @@index([isActive])
}

// ========== MARKETING ==========
model MarketingCampaign {
  id              String    @id @default(uuid())
  name            String
  description     String?   @db.Text
  type            String // EMAIL, SMS, PUSH, IN_APP, LOYALTY
  status          String    @default("DRAFT") // DRAFT, SCHEDULED, ACTIVE, COMPLETED, CANCELLED
  audience        String    @default("ALL") // ALL, VIP, NEW, INACTIVE, CUSTOM
  audienceFilter  Json? // Custom filter spec
  message         String    @db.Text
  subject         String?
  imageUrl        String?
  ctaUrl          String?
  scheduledAt     DateTime?
  sentAt          DateTime?
  recipientsCount Int       @default(0)
  deliveredCount  Int       @default(0)
  openedCount     Int       @default(0)
  clickedCount    Int       @default(0)
  branchId        String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  branch     Branch?             @relation(fields: [branchId], references: [id])
  recipients CampaignRecipient[]

  @@index([status])
  @@index([branchId])
  @@index([scheduledAt])
}

model CampaignRecipient {
  id           String    @id @default(uuid())
  campaignId   String
  customerId   String
  status       String    @default("PENDING") // PENDING, SENT, DELIVERED, OPENED, CLICKED, FAILED
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  errorMessage String?

  campaign MarketingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer          @relation(fields: [customerId], references: [id])

  @@unique([campaignId, customerId])
  @@index([campaignId])
  @@index([customerId])
}

// Customer reviews / feedback
model CustomerReview {
  id            String    @id @default(uuid())
  orderId       String?
  customerId    String?
  rating        Int // 1-5
  foodRating    Int?
  serviceRating Int?
  comment       String?   @db.Text
  source        String    @default("IN_APP") // IN_APP, GOOGLE, FACEBOOK, FOODPANDA
  status        String    @default("PUBLISHED") // PUBLISHED, HIDDEN, REPLIED
  reply         String?   @db.Text
  repliedAt     DateTime?
  repliedById   String?
  branchId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  order    Order?    @relation(fields: [orderId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])

  @@index([orderId])
  @@index([customerId])
  @@index([rating])
  @@index([branchId])
}

// ========== FINANCE / ACCOUNTING ==========
model ChartOfAccounts {
  id          String   @id @default(uuid())
  code        String   @unique // e.g. "1000", "4001"
  name        String
  type        String // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  parentId    String?
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   ChartOfAccounts?  @relation("AccountTree", fields: [parentId], references: [id])
  children ChartOfAccounts[] @relation("AccountTree")
  lines    JournalLine[]

  @@index([type])
  @@index([code])
}

model JournalEntry {
  id          String   @id @default(uuid())
  entryNumber String   @unique
  date        DateTime @default(now())
  description String?
  reference   String? // Order ID, payment ID, expense ID, etc.
  refType     String? // ORDER, PAYMENT, EXPENSE, MANUAL
  totalDebit  Decimal  @default(0) @db.Decimal(14, 2)
  totalCredit Decimal  @default(0) @db.Decimal(14, 2)
  status      String   @default("POSTED") // DRAFT, POSTED, VOIDED
  branchId    String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines  JournalLine[]
  branch Branch?       @relation(fields: [branchId], references: [id])

  @@index([date])
  @@index([refType, reference])
  @@index([branchId])
}

model JournalLine {
  id          String  @id @default(uuid())
  entryId     String
  accountId   String
  debit       Decimal @default(0) @db.Decimal(14, 2)
  credit      Decimal @default(0) @db.Decimal(14, 2)
  description String?

  entry   JournalEntry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account ChartOfAccounts @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@index([accountId])
}

// ========== TAX INTEGRATIONS (FBR / PRA / SRB) ==========
model TaxFiling {
  id               String    @id @default(uuid())
  authority        String // FBR, PRA, SRB
  invoiceNumber    String    @unique
  orderId          String?   @unique
  fbrInvoiceNumber String? // External reference returned by tax portal
  amount           Decimal   @db.Decimal(14, 2)
  taxAmount        Decimal   @db.Decimal(12, 2)
  status           String    @default("PENDING") // PENDING, SUBMITTED, ACCEPTED, REJECTED
  submittedAt      DateTime?
  responseBody     Json?
  errorMessage     String?
  branchId         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  order  Order?  @relation(fields: [orderId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([authority])
  @@index([status])
  @@index([branchId])
}

// ========== EXTERNAL DELIVERY PLATFORMS (Foodpanda etc.) ==========
model ExternalPlatformOrder {
  id              String    @id @default(uuid())
  platform        String // FOODPANDA, UBEREATS, CAREEM
  externalId      String // Order id on the external platform
  externalStatus  String?
  rawPayload      Json
  orderId         String?   @unique // Mapped local order
  customerName    String?
  customerPhone   String?
  deliveryAddress String?
  totalAmount     Decimal   @default(0) @db.Decimal(14, 2)
  status          String    @default("RECEIVED") // RECEIVED, ACCEPTED, REJECTED, COMPLETED
  receivedAt      DateTime  @default(now())
  acceptedAt      DateTime?
  branchId        String?
  errorMessage    String?

  order  Order?  @relation(fields: [orderId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  @@unique([platform, externalId])
  @@index([platform])
  @@index([status])
  @@index([branchId])
}

// ========== QR / SELF-SERVICE ORDERING ==========
model QrSession {
  id         String    @id @default(uuid())
  token      String    @unique
  tableId    String?
  branchId   String?
  customerId String?
  status     String    @default("ACTIVE") // ACTIVE, ORDERED, CLOSED, EXPIRED
  startedAt  DateTime  @default(now())
  expiresAt  DateTime
  closedAt   DateTime?

  table    Table?    @relation(fields: [tableId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  orders   Order[]   @relation("QrSessionOrders")

  @@index([token])
  @@index([tableId])
  @@index([status])
  @@index([expiresAt])
}

// ========== STAFF SCHEDULING ==========
model StaffSchedule {
  id                  String   @id @default(uuid())
  userId              String
  date                DateTime @db.Date
  startTime           String
  endTime             String
  breakDuration       Int      @default(30)
  role                String?
  notes               String?
  status              String   @default("SCHEDULED")
  isRecurring         Boolean  @default(false)
  recurrencePattern   String?
  recurrenceEndDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation("ScheduledUser", fields: [userId], references: [id], onDelete: Cascade)
  swapRequests ShiftSwapRequest[]

  @@index([userId])
  @@index([date])
  @@index([status])
}

model ShiftSwapRequest {
  id             String    @id @default(uuid())
  scheduleId     String
  requesterId    String
  targetUserId   String
  reason         String
  status         String    @default("PENDING")
  responseReason String?
  respondedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedule   StaffSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  requester  User          @relation("SwapRequester", fields: [requesterId], references: [id])
  targetUser User          @relation("SwapTarget", fields: [targetUserId], references: [id])

  @@index([scheduleId])
  @@index([requesterId])
  @@index([targetUserId])
  @@index([status])
}
