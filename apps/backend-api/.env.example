# Server Configuration
PORT=3001
NODE_ENV=development

# Database (MySQL)
# IMPORTANT: Change default credentials before deployment!
DATABASE_URL="mysql://root:YOUR_SECURE_PASSWORD@127.0.0.1:3306/restaurant_pos"

# JWT
# IMPORTANT: Generate a secure random key (min 32 characters) for production!
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="GENERATE_SECURE_RANDOM_KEY_MIN_32_CHARS"
JWT_EXPIRES_IN="24h"

# CORS
# IMPORTANT: Replace * with your specific domains in production!
CORS_ORIGIN="*"

# Logging
LOG_LEVEL=info

# Rate Limiting
# Auth endpoints have stricter limits (5 attempts per 15 min)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# SMS (Optional)
SMS_API_KEY=
SMS_API_SECRET=

# Payment Gateway
# CRITICAL: Required for production payment processing
# Use live keys (sk_live_*) for production, test keys (sk_test_*) for development
STRIPE_SECRET_KEY="sk_live_YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET"
PAYPAL_CLIENT_ID=

# Cloud Storage (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1
