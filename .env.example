# ==========================================
# Restaurant POS - Environment Configuration
# ==========================================

# Database Configuration (MySQL)
DB_ROOT_PASSWORD=your_secure_root_password
DB_NAME=restaurant_pos
DB_USER=pos_user
DB_PASSWORD=your_secure_password
DATABASE_URL="mysql://${DB_USER}:${DB_PASSWORD}@localhost:3306/${DB_NAME}?schema=public"

# Backend API Configuration
NODE_ENV=production
PORT=3001
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
CORS_ORIGIN=http://localhost:3002

# Frontend Configuration (POS Desktop)
VITE_API_URL=http://localhost:3001/api/v1
VITE_SOCKET_URL=http://localhost:3001

# Web Admin Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Stripe Configuration (Payment Gateway)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Thermal Printer Configuration (Optional)
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100

# Cloud Storage (Optional - for backups)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=your_bucket_name

# Feature Flags
ENABLE_LOYALTY=true
ENABLE_COMMISSION=true
ENABLE_KITCHEN_DISPLAY=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ==========================================
# SEED DATA PASSWORDS (CHANGE IN PRODUCTION!)
# ==========================================
# These are used during database seeding. 
# In production, set these to unique secure values.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_FULL_NAME=System Administrator
SEED_ADMIN_EMAIL=admin@restaurant.local
SEED_ADMIN_PASSWORD=replace_with_unique_admin_password
SEED_ADMIN_PIN=replace_with_unique_admin_pin
SEED_INCLUDE_DEMO_USERS=false
ALLOW_DESTRUCTIVE_SEED=false
