{
  "name": "restaurant-pos-system",
  "version": "1.0.0",
  "description": "Modern Restaurant POS System with Offline-First Architecture",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:pos\"",
    "dev:pos": "cd apps/pos-desktop && npm run dev",
    "dev:api": "cd apps/backend-api && npm run dev",
    "dev:web": "cd apps/web-admin && npm run dev",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:pos\" \"npm run dev:web\"",
    "build": "npm run build:pos && npm run build:api && npm run build:web",
    "build:pos": "cd apps/pos-desktop && npm run build",
    "build:api": "cd apps/backend-api && npm run build",
    "build:web": "cd apps/web-admin && npm run build",
    "db:generate": "cd apps/backend-api && npx prisma generate",
    "db:migrate": "cd apps/backend-api && npx prisma migrate dev",
    "db:studio": "cd apps/backend-api && npx prisma studio",
    "db:seed": "cd apps/backend-api && npm run seed",
    "db:seed:defaults": "cd apps/backend-api && npm run seed:defaults",
    "typecheck": "npm run typecheck:api && npm run typecheck:web && npm run typecheck:pos",
    "typecheck:api": "cd apps/backend-api && npm run typecheck",
    "typecheck:web": "cd apps/web-admin && npx tsc --noEmit",
    "typecheck:pos": "cd apps/pos-desktop && npx tsc --noEmit",
    "lint:queries": "cd apps/backend-api && npm run lint:queries",
    "test": "cd apps/backend-api && npm test",
    "precommit": "npm run lint:queries && npm run typecheck:api",
    "prepare": "husky install || true"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
